# Database (Railway Postgres auto-sets this on deploy)
DATABASE_URL="postgresql://postgres:password@localhost:5432/gde_seo_portal"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# GSC Service Account (path to the JSON key file)
GSC_CREDENTIALS_PATH="../credentials/gsc-service-account.json"
GSC_SITE_URL="sc-domain:getdriversed.com"

# SEO Repo root (for reading pages/ and tracker/ folders)
SEO_REPO_ROOT="/path/to/getdriversed-seo"

# Admin seed credentials (used once at first seed — change after)
SEED_ADMIN_EMAIL="admin@getdriversed.com"
SEED_ADMIN_NAME="Admin"
